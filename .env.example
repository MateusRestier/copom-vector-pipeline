# ─────────────────────────────────────────────
#  Provider Selection
#  Change the value to switch providers without touching any code.
#  Supported values: gemini  (openai, azure — add your own provider in src/copom_pipeline/providers/)
# ─────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini

# ─────────────────────────────────────────────
#  Google Gemini
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
# Dimensionality of the embedding model above — used at schema creation time.
# Must match GEMINI_EMBEDDING_MODEL (text-embedding-004 → 768).
EMBEDDING_DIMENSIONS=768

# ─────────────────────────────────────────────
#  PostgreSQL + pgvector
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://copom:copom@localhost:5432/copom_rag

# ─────────────────────────────────────────────
#  Pipeline tuning
# ─────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=20
BATCH_SIZE=50
CHECKPOINT_INTERVAL=20

# ─────────────────────────────────────────────
#  BCB downloader
# ─────────────────────────────────────────────
# Polite delay between HTTP requests to BCB servers (seconds).
BCB_REQUEST_DELAY_SECONDS=1.0
BCB_MAX_RETRIES=3
